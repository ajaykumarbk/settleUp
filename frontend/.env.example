# Google OAuth Configuration for Vite Frontend
# In Vite, environment variables must start with VITE_ to be exposed to the client.
VITE_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# Backend API Base URL (leave blank in local development to use dev proxy, or set to your Render backend URL in production)
VITE_API_BASE=https://your-backend-app.onrender.com
