# Express Server Config
PORT=5000
NODE_ENV=development

# Database Connection (MySQL)
# If using the Oracle Cloud VM database, replace DB_HOST with the VM's public IP
# and ensure port 3306 is open in Oracle Cloud VCN ingress rules and local firewall (ufw).
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_db_password
DB_NAME=splitwise_db

# Security
JWT_SECRET=replace_this_with_a_secure_random_key_in_production
JWT_EXPIRE=7d
